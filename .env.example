# Threadline environment configuration.
#
# Copy to `.env` and fill in. For local M1/M2 work you only need DATABASE_URL,
# REDIS_URL, AUTH_SECRET and ENCRYPTION_KEY — the external service keys are wired
# up in later milestones and may stay empty.
#
# Never commit `.env`. Generate secrets with:  openssl rand -base64 32

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
AUTH_SECRET=                      # openssl rand -base64 32
DATABASE_URL=postgres://postgres:postgres@localhost:5434/threadline
REDIS_URL=redis://localhost:6379

# --- LLM (Anthropic via Vercel AI SDK) ---
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6           # verify current string in Anthropic docs

# --- Embeddings (default OpenAI; swappable) ---
EMBEDDINGS_PROVIDER=openai              # openai | voyage | local
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536                      # MUST match the vector() column dim in M2

# --- Twilio (SMS/MMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=           # or set TWILIO_FROM_NUMBER
TWILIO_FROM_NUMBER=
SEND_REAL_SMS=false                     # HARD GATE: real outbound only when true

# --- Shopify (custom app, single store for V1) ---
SHOPIFY_SHOP_DOMAIN=                     # my-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=                     # latest stable date version, verify in docs
SHOPIFY_WEBHOOK_SECRET=

# --- Slack (escalation notify) ---
SLACK_WEBHOOK_URL=

# --- Langfuse (optional tracing) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# --- Tracking (optional; heuristic default in V1) ---
TRACKING_PROVIDER=heuristic              # heuristic | easypost
EASYPOST_API_KEY=
DELIVERY_HEURISTIC_DAYS=5

# --- Encryption (for integration creds at rest) ---
ENCRYPTION_KEY=                          # 32-byte base64; used in M2/M4
